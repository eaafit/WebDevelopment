// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Applicant @map("applicant")
  Notary    @map("notary")
  Admin     @map("admin")

  @@map("role")
}

enum AssessmentStatus {
  New        @map("new")
  Verified   @map("verified")
  InProgress @map("in_progress")
  Completed  @map("completed")
  Cancelled  @map("cancelled")

  @@map("assessment_status")
}

enum SubscriptionPlan {
  Basic      @map("basic")
  Premium    @map("premium")
  Enterprise @map("enterprise")

  @@map("subscription_plan")
}

enum PaymentType {
  Subscription @map("subscription")
  Assessment   @map("assessment")
  DocumentCopy @map("document_copy")

  @@map("payment_type")
}

enum PaymentStatus {
  Pending   @map("pending")
  Completed @map("completed")
  Failed    @map("failed")
  Refunded  @map("refunded")

  @@map("payment_status")
}

enum PaymentReceiptStatus {
  Pending   @map("pending")
  Available @map("available")
  Failed    @map("failed")

  @@map("payment_receipt_status")
}

enum NotificationType {
  Email @map("email")
  SMS   @map("sms")
  Push  @map("push")
  InApp @map("in_app")

  @@map("notification_type")
}

enum NotificationStatus {
  Pending @map("pending")
  Sent    @map("sent")
  Failed  @map("failed")

  @@map("notification_status")
}

enum NotificationPreferenceChannel {
  Email @map("email")
  Sms   @map("sms")
  Push  @map("push")
  InApp @map("in_app")

  @@map("notification_preference_channel")
}

enum NotificationCategory {
  Application @map("application")
  Document    @map("document")
  Payment     @map("payment")
  System      @map("system")
  Assessment  @map("assessment")

  @@map("notification_category")
}

enum NotificationEntityCategory {
  Assessment @map("assessment")
  Payment    @map("payment")
  System     @map("system")

  @@map("notification_entity_category")
}

enum NotificationPreferenceStatus {
  Active   @map("active")
  Inactive @map("inactive")

  @@map("notification_preference_status")
}

enum NewsletterSubscriptionStatus {
  Active       @map("active")
  Unsubscribed @map("unsubscribed")

  @@map("newsletter_subscription_status")
}

enum NewsletterAudienceType {
  All      @map("all")
  Role     @map("role")
  Selected @map("selected")

  @@map("newsletter_audience_type")
}

enum NewsletterCampaignStatus {
  Sending       @map("sending")
  Sent          @map("sent")
  Failed        @map("failed")
  PartialFailed @map("partial_failed")

  @@map("newsletter_campaign_status")
}

enum NewsletterDeliveryStatus {
  Pending @map("pending")
  Sent    @map("sent")
  Failed  @map("failed")

  @@map("newsletter_delivery_status")
}

enum SaleType {
  Permanent    @map("permanent")
  Subscription @map("subscription")
  Product      @map("product")
  Promo        @map("promo")

  @@map("sale_type")
}

// [FIX] Добавлен enum для статуса отчёта (использует ReportService)
enum ReportStatus {
  Draft  @map("draft")
  Signed @map("signed")

  @@map("report_status")
}

// [FIX] Добавлен enum для типа документа (был в proto, отсутствовал в схеме)
enum DocumentType {
  Passport          @map("passport")
  PropertyDeed      @map("property_deed")
  TechnicalPlan     @map("technical_plan")
  CadastralPassport @map("cadastral_passport")
  Photo             @map("photo")
  Other             @map("other")
  Additional        @map("additional")

  @@map("document_type")
}

enum RealEstateObjectType {
  Apartment          @map("apartment")
  House              @map("house")
  Room               @map("room")
  Apartments         @map("apartments")
  LandPlot           @map("land_plot")
  CommercialProperty @map("commercial_property")
  Other              @map("other")

  @@map("real_estate_object_type")
}

enum RealEstateCondition {
  Excellent    @map("excellent")
  Good         @map("good")
  Satisfactory @map("satisfactory")
  Poor         @map("poor")

  @@map("real_estate_condition")
}

enum WallMaterial {
  Brick           @map("brick")
  Panel           @map("panel")
  Block           @map("block")
  Monolithic      @map("monolithic")
  MonolithicBrick @map("monolithic_brick")
  Wooden          @map("wooden")
  AeratedConcrete @map("aerated_concrete")

  @@map("wall_material")
}

enum ElevatorType {
  None              @map("none")
  Cargo             @map("cargo")
  Passenger         @map("passenger")
  PassengerAndCargo @map("passenger_and_cargo")

  @@map("elevator_type")
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar
  passwordHash String   @map("password_hash") @db.VarChar
  fullName     String   @map("full_name") @db.VarChar
  role         Role     @default(Applicant)
  phoneNumber  String?  @map("phone_number") @db.VarChar
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // [FIX] Именованные relations для двух FK из Assessment
  assessments       Assessment[]       @relation("ApplicantAssessments")
  notaryAssessments Assessment[]       @relation("NotaryAssessments")
  subscriptions     Subscription[]
  payments          Payment[]
  uploadedDocuments Document[]         @relation("UploadedBy")
  signedReports     AssessmentReport[] @relation("SignedBy")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  auditLogs         AuditLog[]
  bitrixSyncLogs    BitrixSyncLog[]
  clientSync        ClientSync?
  newsletterSubscription NewsletterSubscription?
  newsletterCampaigns    NewsletterCampaign[]    @relation("NewsletterCampaignCreatedBy")
  newsletterDeliveries   NewsletterDelivery[]

  applicantLeads Lead[] @relation("ApplicantLeads")
  executorLeads  Lead[] @relation("ExecutorLeads")

  @@map("users")
}

model City {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @unique @db.VarChar
  districts         District[]
  realEstateObjects RealEstateObject[]

  @@map("cities")
}

model District {
  id                String             @id @default(uuid()) @db.Uuid
  cityId            String             @map("city_id") @db.Uuid
  name              String             @db.VarChar
  city              City               @relation(fields: [cityId], references: [id])
  realEstateObjects RealEstateObject[]

  @@unique([cityId, name])
  @@index([cityId])
  @@map("districts")
}

model RealEstateObject {
  id                  String                @id @default(uuid()) @db.Uuid
  cityId              String                @map("city_id") @db.Uuid
  districtId          String?               @map("district_id") @db.Uuid
  address             String                @db.VarChar
  cadastralNumber     String?               @map("cadastral_number") @db.VarChar
  area                Decimal               @db.Decimal(10, 2)
  objectType          RealEstateObjectType  @map("object_type")
  roomsCount          Int?                  @map("rooms_count")
  floorsTotal         Int?                  @map("floors_total")
  floor               Int?
  condition           RealEstateCondition?  @map("condition")
  yearBuilt           Int?                  @map("year_built")
  wallMaterial        WallMaterial?         @map("wall_material")
  elevatorType        ElevatorType?         @map("elevator_type")
  hasBalconyOrLoggia  Boolean?              @map("has_balcony_or_loggia")
  landCategory        String?               @map("land_category") @db.VarChar
  permittedUse        String?               @map("permitted_use") @db.VarChar
  utilities           String?               @db.Text
  description         String?               @db.Text
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamp()
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamp()

  city       City       @relation(fields: [cityId], references: [id])
  district   District?  @relation(fields: [districtId], references: [id])
  assessment Assessment?

  @@index([cityId])
  @@index([districtId])
  @@index([objectType])
  @@map("real_estate_objects")
}

model Assessment {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  notaryId           String?          @map("notary_id") @db.Uuid               // [FIX] назначенный нотариус
  realEstateObjectId String?          @unique @map("real_estate_object_id") @db.Uuid
  status             AssessmentStatus @default(New)
  cancelReason       String?          @map("cancel_reason") @db.Text           // [FIX] причина отмены
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamp()
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamp()
  address            String           @db.VarChar
  description        String?          @db.Text
  estimatedValue     Decimal?         @map("estimated_value") @db.Decimal(15, 2)
  bitrixLeadId       String?          @map("bitrix_lead_id") @db.VarChar(50)

  user             User              @relation("ApplicantAssessments", fields: [userId], references: [id])
  notary           User?             @relation("NotaryAssessments", fields: [notaryId], references: [id])
  realEstateObject RealEstateObject? @relation(fields: [realEstateObjectId], references: [id])
  documents        Document[]
  reports          AssessmentReport[]
  payments         Payment[]

  lead Lead?

  @@map("assessments")
}

model Document {
  id           String       @id @default(uuid()) @db.Uuid
  assessmentId String       @map("assessment_id") @db.Uuid
  fileName     String       @map("file_name") @db.VarChar
  fileType     String       @map("file_type") @db.VarChar
  fileSize     Int          @map("file_size")
  documentType DocumentType @default(Other) @map("document_type") // [FIX] добавлен enum-тип
  bucketName   String       @map("bucket_name") @db.VarChar
  objectKey    String       @map("object_key") @db.VarChar
  version      Int          @default(1)
  uploadedAt   DateTime     @default(now()) @map("uploaded_at") @db.Timestamp()
  uploadedById String       @map("uploaded_by") @db.Uuid

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  uploadedBy User       @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@map("documents")
}

model Subscription {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  plan      SubscriptionPlan
  basePrice Decimal?         @map("base_price") @db.Decimal(15, 2) // [FIX] цена тарифа на момент покупки
  currency  String           @default("RUB") @map("currency") @db.VarChar(3)
  startDate DateTime         @map("start_date") @db.Date
  endDate   DateTime         @map("end_date") @db.Date
  isActive  Boolean          @default(true) @map("is_active")

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]
  sales    Sale[]

  @@map("subscriptions")
}

model Payment {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @map("user_id") @db.Uuid
  type               PaymentType
  subscriptionId     String?               @map("subscription_id") @db.Uuid
  assessmentId       String?               @map("assessment_id") @db.Uuid
  promoId            String?               @map("promo_id") @db.Uuid // [FIX] применённый промокод
  amount             Decimal               @db.Decimal(15, 2)
  discountAmount     Decimal?              @map("discount_amount") @db.Decimal(15, 2) // [FIX] сумма скидки
  paymentDate        DateTime              @default(now()) @map("payment_date") @db.Timestamp()
  status             PaymentStatus         @default(Pending)
  paymentMethod      String?               @map("payment_method") @db.VarChar
  transactionId      String?               @unique @map("transaction_id") @db.VarChar
  attachmentFileName String?               @map("attachment_file_name") @db.VarChar
  attachmentFileUrl  String?               @map("attachment_file_url") @db.VarChar
  receiptStatus      PaymentReceiptStatus? @map("receipt_status")

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  assessment   Assessment?   @relation(fields: [assessmentId], references: [id])
  promo        Promo?        @relation(fields: [promoId], references: [id])

  @@map("payments")
}

model AssessmentReport {
  id            String       @id @default(uuid()) @db.Uuid
  assessmentId  String       @map("assessment_id") @db.Uuid
  reportPath    String       @map("report_path") @db.VarChar
  generatedAt   DateTime     @default(now()) @map("generated_at") @db.Timestamp()
  signedById    String       @map("signed_by") @db.Uuid
  signatureData Bytes?       @map("signature_data")
  version       Int          @default(1)
  status        ReportStatus @default(Draft) @map("status") // [FIX] статус отчёта

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  signedBy   User       @relation("SignedBy", fields: [signedById], references: [id])

  @@map("assessment_reports")
}

model Notification {
  id       String                 @id @default(uuid()) @db.Uuid
  userId   String                 @map("user_id") @db.Uuid
  type     NotificationType
  category NotificationCategory @default(System)
  title    String                 @default("Уведомление") @db.VarChar
  message  String                 @db.Text
  sentAt   DateTime               @default(now()) @map("sent_at") @db.Timestamp()
  readAt   DateTime?              @map("read_at") @db.Timestamp() // [FIX] время прочтения
  status   NotificationStatus     @default(Pending)

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model NotificationPreference {
  id             String                       @id @default(uuid()) @db.Uuid
  userId         String                       @map("user_id") @db.Uuid
  channel        NotificationPreferenceChannel @map("channel")
  entityCategory NotificationEntityCategory   @map("entity_category")
  status         NotificationPreferenceStatus @default(Active) @map("status")
  updatedAt      DateTime                     @updatedAt @map("updated_at") @db.Timestamp()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, entityCategory])
  @@index([userId])
  @@map("notification_preferences")
}

model NewsletterSubscription {
  id             String                       @id @default(uuid()) @db.Uuid
  userId         String                       @unique @map("user_id") @db.Uuid
  status         NewsletterSubscriptionStatus @default(Active)
  subscribedAt   DateTime                     @default(now()) @map("subscribed_at") @db.Timestamp()
  unsubscribedAt DateTime?                    @map("unsubscribed_at") @db.Timestamp()
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamp()
  updatedAt      DateTime                     @updatedAt @map("updated_at") @db.Timestamp()

  user User @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([subscribedAt(sort: Desc)])
  @@map("newsletter_subscriptions")
}

model NewsletterCampaign {
  id              String                   @id @default(uuid()) @db.Uuid
  createdById     String?                  @map("created_by") @db.Uuid
  subject         String                   @db.VarChar(200)
  bodyHtml        String                   @map("body_html") @db.Text
  audienceType    NewsletterAudienceType   @map("audience_type")
  audienceRole    Role?                    @map("audience_role")
  audienceLabel   String                   @map("audience_label") @db.VarChar(255)
  recipientsCount Int                      @default(0) @map("recipients_count")
  sentCount       Int                      @default(0) @map("sent_count")
  failedCount     Int                      @default(0) @map("failed_count")
  status          NewsletterCampaignStatus @default(Sending)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamp()
  completedAt     DateTime?                @map("completed_at") @db.Timestamp()

  createdBy  User?                @relation("NewsletterCampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  deliveries NewsletterDelivery[]

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([createdById])
  @@map("newsletter_campaigns")
}

model NewsletterDelivery {
  id           String                   @id @default(uuid()) @db.Uuid
  campaignId   String                   @map("campaign_id") @db.Uuid
  userId       String?                  @map("user_id") @db.Uuid
  email        String                   @db.VarChar
  fullName     String                   @map("full_name") @db.VarChar
  status       NewsletterDeliveryStatus @default(Pending)
  errorMessage String?                  @map("error_message") @db.Text
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamp()
  sentAt       DateTime?                @map("sent_at") @db.Timestamp()

  campaign NewsletterCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([campaignId, email])
  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@map("newsletter_deliveries")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar
  expiresAt DateTime  @map("expires_at") @db.Timestamp()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()
  revokedAt DateTime? @map("revoked_at") @db.Timestamp()

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar
  expiresAt DateTime  @map("expires_at") @db.Timestamp()
  usedAt    DateTime? @map("used_at") @db.Timestamp()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_resets")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  actorEmail String?  @map("actor_email") @db.VarChar
  actorName  String?  @map("actor_name") @db.VarChar
  actorRole  Role?    @map("actor_role")
  actionType String   @map("action_type") @db.VarChar
  entityName String   @map("entity_name") @db.VarChar
  entityId   String?  @map("entity_id") @db.Uuid
  timestamp  DateTime @default(now()) @db.Timestamp()
  details    Json?    @db.JsonB

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([timestamp(sort: Desc)])
  @@index([actionType])
  @@index([entityId])
  @@index([userId])
  @@index([actorEmail])
  @@index([actorName])
  @@index([entityName, entityId])
  @@index([entityName, entityId, timestamp(sort: Desc)])
  @@map("audit_logs")
}

model Promo {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique @db.VarChar
  description     String?   @db.Text
  discountPercent Decimal   @map("discount_percent") @db.Decimal(5, 2) // [FIX] размер скидки
  usageLimit      Int?      @map("usage_limit") // [FIX] лимит использований
  usedCount       Int       @default(0) @map("used_count") // [FIX] счётчик применений
  expiresAt       DateTime? @map("expires_at") @db.Timestamp() // [FIX] срок действия

  payments Payment[]
  sales    Sale[]

  @@map("promos")
}

model Sale {
  id             String   @id @default(uuid()) @db.Uuid
  type           SaleType
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  percent        Decimal  @db.Decimal(5, 2)
  isActive       Boolean  @default(true) @map("is_active") // [FIX] флаг активности
  subscriptionId String?  @map("subscription_id") @db.Uuid // [FIX] типизированный FK вместо sourceId
  promoId        String?  @map("promo_id") @db.Uuid // [FIX] типизированный FK вместо sourceId

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  promo        Promo?        @relation(fields: [promoId], references: [id])

  @@map("sales")
}

// ─── Bitrix Integration ──────────────────────────────────────────────────────

model BitrixConfig {
  id          String   @id @default(uuid()) @db.Uuid
  portalUrl   String   @map("portal_url")   @db.VarChar(255)
  memberId    String   @map("member_id")    @db.VarChar(100)
  accessToken String   @map("access_token") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp()

  @@map("bitrix_config")
}

model BitrixSync {
  id                String   @id @default(uuid()) @db.Uuid
  jobId             String   @map("job_id") @db.VarChar(100)
  status            String   @db.VarChar(20) // "pending", "running", "completed", "failed"
  totalUsers        Int      @default(0) @map("total_users")
  processedUsers    Int      @default(0) @map("processed_users")
  successfulSyncs   Int      @default(0) @map("successful_syncs")
  failedSyncs       Int      @default(0) @map("failed_syncs")
  errorMessage      String?  @map("error_message") @db.Text
  startedAt         DateTime @map("started_at") @db.Timestamp()
  completedAt       DateTime? @map("completed_at") @db.Timestamp()
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp()

  logs BitrixSyncLog[]

  @@map("bitrix_sync")
}

model BitrixSyncLog {
  id                String   @id @default(uuid()) @db.Uuid
  syncId            String   @map("sync_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  bitrixContactId   String?  @map("bitrix_contact_id") @db.VarChar(50)
  action            String   @db.VarChar(20) // "created", "updated", "skipped", "error"
  status            String   @db.VarChar(10) // "success", "error"
  message           String?  @db.Text
  timestamp         DateTime @default(now()) @db.Timestamp()

  sync              BitrixSync @relation(fields: [syncId], references: [id])
  user              User       @relation(fields: [userId], references: [id])

  @@map("bitrix_sync_log")
}

model ClientSync {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  bitrixContactId   String?  @map("bitrix_contact_id") @db.VarChar(50)
  syncDirection     String   @default("notary") @map("sync_direction") @db.VarChar(10)
  lastSyncedAt      DateTime? @map("last_synced_at") @db.Timestamp()
  lastNotaryHash    String?  @map("last_notary_hash") @db.VarChar(64)
  lastBitrixHash    String?  @map("last_bitrix_hash") @db.VarChar(64)
  conflictCount     Int      @default(0) @map("conflict_count")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamp()

  user              User     @relation(fields: [userId], references: [id])

  @@map("client_sync")
}

model Lead {
  id                     String   @id @default(uuid())
  applicantId            String   @db.Uuid @map("applicant_id")
  executorId             String?  @db.Uuid @map("executor_id")
  assessmentId           String   @db.Uuid @unique @map("assessment_id")
  startDate              DateTime @map("start_date") @default(now())
  plannedCompletionDate  DateTime @map("planned_completion_date")
  actualCompletionDate   DateTime? @map("actual_completion_date")
  transactionId          String?  @map("transaction_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  applicant   User   @relation("ApplicantLeads", fields: [applicantId], references: [id], onDelete: Cascade)
  executor    User?  @relation("ExecutorLeads", fields: [executorId], references: [id])
  assessment  Assessment @relation(fields: [assessmentId], references: [id])

  @@index([applicantId])
  @@index([executorId])
  @@index([assessmentId])
  @@map("leads")
}
