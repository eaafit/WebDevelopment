DB_NAME=db
DB_PORT=5432
DB_USER=admin
DB_PASS=admin
DATABASE_URL="postgresql://admin:admin@localhost:5432/db?schema=public"

# JWT — обязательно сменить в продакшне на длинные случайные строки
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-in-production-use-crypto-random-64-bytes
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# OAuth — вход через внешние сервисы (Google / Яндекс / ВК).
# Создайте OAuth-клиент типа «Web application» в Google Cloud Console и пропишите
# там Authorized redirect URI, совпадающий с GOOGLE_REDIRECT_URI ниже.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4200/auth/oauth/google/callback
# Яндекс OAuth (oauth.yandex.ru → создать приложение, платформа «Веб-сервисы»,
# права «Доступ к адресу эл. почты» + «Доступ к логину, имени и фамилии»).
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_REDIRECT_URI=http://localhost:4200/auth/oauth/yandex/callback
# VK ID (id.vk.ru → создать приложение). OAuth 2.1 + PKCE: client_secret обычно не
# требуется (его заменяет PKCE), укажите VK_CLIENT_SECRET только если того требует тип приложения.
VK_CLIENT_ID=your_vk_client_id
VK_REDIRECT_URI=http://localhost:4200/auth/oauth/vk/callback
# VK_CLIENT_SECRET=your_vk_client_secret
# Секрет подписи OAuth state (CSRF). В проде обязателен (иначе fail-fast);
# вне прода при отсутствии используется JWT_ACCESS_SECRET с предупреждением.
OAUTH_STATE_SECRET=change-me-use-crypto-random-32-bytes
# Время жизни state в секундах (по умолчанию 600 = 10 минут).
OAUTH_STATE_TTL_SEC=600
# Подтверждение контакта после OAuth-регистрации/первой связки (код в лог api, SMTP не нужен).
CONTACT_CODE_TTL_SEC=300            # срок жизни кода, сек (5 минут)
CONTACT_CODE_MAX_ATTEMPTS=5         # лимит попыток ввода кода
CONTACT_CODE_RESEND_COOLDOWN_SEC=60 # серверный кулдаун между отправками кода
CONTACT_TICKET_TTL_SEC=600          # срок жизни ticket подтверждения, сек (10 минут)

# API / Web
PORT=3000
FRONTEND_URL=http://localhost:4200
# Структурированные логи API: trace | debug | info | warn | error | fatal | silent.
# Если не задано: NODE_ENV=production использует info, остальные окружения используют debug.
LOG_LEVEL=info

# OpenTelemetry tracing API -> Tempo.
# API на хосте: http://localhost:4318.
# API внутри Docker-сети с сервисом tempo: http://tempo:4318.
# Docker-контейнер в другой compose-сети на Docker Desktop: http://host.docker.internal:4318.
OTEL_SERVICE_NAME=notary-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_PROPAGATORS=tracecontext,baggage

# Grafana (docker-compose)
GF_ADMIN_PASSWORD=admin
# ФИАС: сейчас активна stub-реализация. Для будущего подключения реального SPAS API:
# FIAS_PROVIDER=real
# FIAS_MASTER_TOKEN=<master-token-from-fias.nalog.ru>
# FIAS_BASE_URL=https://fias-public-service.nalog.ru/api/spas/v2.0
FIAS_PROVIDER=stub

# Почта: SMTP и/или EmailJS (см. MAIL_TRANSPORT).
PASSWORD_RESET_BASE_URL=http://localhost:4200
PASSWORD_RESET_TTL_SEC=3600
MAIL_TRANSPORT=smtp
# auto | smtp | emailjs — при auto: при полной настройке EmailJS используется он, иначе SMTP при наличии, иначе только лог.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com
APP_NAME=Notary portal
#
# Локальный предпросмотр писем через Mailpit из docker-compose:
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# MAIL_FROM=noreply@notary-portal.local
MAILPIT_UI_PORT=8025
#
# EmailJS (сервер, private key в кабинете Account → Security → API keys)
# EMAILJS_SERVICE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=
# EMAILJS_TEMPLATE_PASSWORD_RESET=
# EMAILJS_TEMPLATE_WELCOME_REGISTERED=
# EMAILJS_TEMPLATE_APPLICANT_REQUEST=
# EMAILJS_TEMPLATE_STAFF_NEW_REQUEST=
# Для уведомления сотрудника о новой заявке (если шаблон использует переменную to_email)
# EMAILJS_STAFF_NOTIFY_TO=

# YooKassa
# PAYMENT_PROVIDER=YooKassa
YOOKASSA_SHOP_ID=your_test_shop_id
YOOKASSA_SECRET_KEY=your_test_secret_key
PAYMENT_RETURN_URL_BASE=http://localhost:4200
PAYMENT_WEBHOOK_SECRET=your_local_webhook_secret
PAYMENT_PROVIDER=robokassa
# Обязательно для чеков подписки: явный vat_code для строки чека в YooKassa.
# Значение должно быть согласовано с бухгалтерией/настройками кассы.
# YOOKASSA_RECEIPT_VAT_CODE=<set-explicitly>

# Robokassa
ROBOKASSA_MERCHANT_LOGIN=Test1999
ROBOKASSA_PASSWORD_1=password_1
ROBOKASSA_PASSWORD_2=password_2
ROBOKASSA_TEST_MODE=true
# Тестовые данные с документации

# MinIO (docker-compose) — учётные данные сервера; совпадают с S3_ACCESS_KEY / S3_SECRET_KEY при локальной разработке
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# S3-совместимое API (локально — MinIO; в проде — endpoint региона AWS или другого провайдера)
# Документы модулей: payment — S3StorageService (вложения к платежам), assessment — DocumentStorageService (файлы заявок).
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Для MinIO и многих on-prem: true. Для публичного AWS S3 обычно false (или не задавайте).
S3_FORCE_PATH_STYLE=true
# Бакет PDF/чеков к платежам (minio-init в docker-compose создаёт его по умолчанию)
S3_BUCKET_PAYMENT_DOCUMENTS=payment-documents
# Бакет файлов оценки/документов заявок (создайте в MinIO вручную или расширьте minio-init)
S3_BUCKET_ASSESSMENT_FILES=assessment-files

# Bitrix24 lead publisher (лаб. работа №6, issue-05, Деркач Е.С.)
# Получить webhook URL: Битрикс24 → Приложения → Разработчикам → Другое → Входящий вебхук.
# Минимально необходимые права webhook: CRM (для crm.lead.add).
# BITRIX_WEBHOOK_URL — полный URL вебхука, включая код и завершающий "/".
# BITRIX_PORTAL_URL — базовый URL портала без "/rest/..." (для будущих ссылок на лиды из UI).
BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your-token/
BITRIX_PORTAL_URL=https://your-portal.bitrix24.ru

# ИИ-техподдержка (только процесс apps/api — ключи не попадают во фронт)
# Провайдер: gigachat (по умолчанию) | openai
SUPPORT_AI_PROVIDER=gigachat
# Локальная отладка без ключей: true — демо-ответы (только NODE_ENV≠production)
# SUPPORT_AI_STUB=true
# GigaChat: Authorization Key (Base64 ClientID:Secret) из кабинета developers.sber.ru
GIGACHAT_CREDENTIALS=
# Альтернатива credentials: готовый access token или логин/пароль
# GIGACHAT_ACCESS_TOKEN=
# GIGACHAT_USER=
# GIGACHAT_PASSWORD=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_MAX_TOKENS=500
# GIGACHAT_TIMEOUT_SEC=60
# Локально при проблемах с TLS API Сбера: true (в production оставьте false или не задавайте)
# GIGACHAT_INSECURE_TLS=true
# OpenAI (если SUPPORT_AI_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=500
