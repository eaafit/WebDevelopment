# Скопируйте в корневой .env. Корневой .env в .gitignore — не добавляйте в git.
DB_NAME=db
DB_PORT=5432
DB_USER=admin
DB_PASS=admin
DATABASE_URL="postgresql://admin:admin@localhost:5432/db?schema=public"

# JWT — обязательно сменить в продакшне на длинные случайные строки
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-in-production-use-crypto-random-64-bytes
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# API / Web
PORT=3000
FRONTEND_URL=http://localhost:4200

# YooKassa
YOOKASSA_SHOP_ID=your_test_shop_id
YOOKASSA_SECRET_KEY=your_test_secret_key
PAYMENT_RETURN_URL_BASE=http://localhost:4200
PAYMENT_WEBHOOK_SECRET=your_local_webhook_secret

# ИИ техподдержки (SupportService.AskSupportAi) — только на сервере API
# Включён GigaChat; для OpenAI: SUPPORT_AI_PROVIDER=openai и задайте OPENAI_API_KEY
#
# GigaChat — если ключ засветился (чат, скрин, issue): зайдите на developers.sber.ru → ваш проект
# GigaChat API → перевыпустите Client Secret → снова сформируйте Authorization Key
# (Base64 от строки «Client ID:Client Secret», как в инструкции Сбера) → обновите GIGACHAT_CREDENTIALS
# в локальном .env и в секретах CI/сервера. Старый секрет после ротации недействителен.
#
SUPPORT_AI_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=

# Опционально GigaChat
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_MAX_TOKENS=500
GIGACHAT_TIMEOUT_SEC=60
# TLS к API Сбера: при ошибке «self-signed certificate in certificate chain» поставьте true
# или оставьте не задано вне production (в коде для NODE_ENV!=production по умолчанию ослаблена проверка).
# В production без true — строгая проверка; при необходимости подключите корневой сертификат через NODE_EXTRA_CA_CERTS.
GIGACHAT_INSECURE_TLS=

# Ручная проверка OAuth (то же, что делает SDK gigachat). Вместо <Authorization key> — значение GIGACHAT_CREDENTIALS
# (base64 от «Client ID:Client Secret»). RqUID — новый UUID v4 на каждый запрос.
# curl -L -X POST 'https://ngw.devices.sberbank.ru:9443/api/v2/oauth' \
#   -H 'Content-Type: application/x-www-form-urlencoded' \
#   -H 'Accept: application/json' \
#   -H 'RqUID: 00000000-0000-4000-8000-000000000000' \
#   -H 'Authorization: Basic <Authorization key>' \
#   --data-urlencode 'scope=GIGACHAT_API_PERS'

# Альтернатива GIGACHAT_CREDENTIALS (см. конфиг SDK gigachat)
# GIGACHAT_ACCESS_TOKEN=
# GIGACHAT_USER=
# GIGACHAT_PASSWORD=

# OpenAI (если SUPPORT_AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
