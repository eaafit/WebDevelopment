DB_NAME=db
DB_PORT=5432
DB_USER=admin
DB_PASS=admin
DATABASE_URL="postgresql://admin:admin@localhost:5432/db?schema=public"

# JWT — обязательно сменить в продакшне на длинные случайные строки
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-in-production-use-crypto-random-64-bytes
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# API / Web
PORT=3000
FRONTEND_URL=http://localhost:4200

# Почта: SMTP и/или EmailJS (см. MAIL_TRANSPORT).
# PASSWORD_RESET_BASE_URL=http://localhost:4200
# PASSWORD_RESET_TTL_SEC=3600
# MAIL_TRANSPORT=auto
# auto | smtp | emailjs — при auto: при полной настройке EmailJS используется он, иначе SMTP при наличии, иначе только лог.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@example.com
# APP_NAME=Notary portal
#
# EmailJS (сервер, private key в кабинете Account → Security → API keys)
# EMAILJS_SERVICE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=
# EMAILJS_TEMPLATE_PASSWORD_RESET=
# EMAILJS_TEMPLATE_WELCOME_REGISTERED=
# EMAILJS_TEMPLATE_APPLICANT_REQUEST=
# EMAILJS_TEMPLATE_STAFF_NEW_REQUEST=
# Для уведомления сотрудника о новой заявке (если шаблон использует переменную to_email)
# EMAILJS_STAFF_NOTIFY_TO=

# YooKassa
YOOKASSA_SHOP_ID=your_test_shop_id
YOOKASSA_SECRET_KEY=your_test_secret_key
PAYMENT_RETURN_URL_BASE=http://localhost:4200
PAYMENT_WEBHOOK_SECRET=your_local_webhook_secret
# Обязательно для чеков подписки: явный vat_code для строки чека в YooKassa.
# Значение должно быть согласовано с бухгалтерией/настройками кассы.
# YOOKASSA_RECEIPT_VAT_CODE=<set-explicitly>

# MinIO (docker-compose) — совпадают с MINIO_ROOT_* в compose
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# S3-совместимое API (локально — MinIO на хосте)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PAYMENT_DOCUMENTS=payment-documents
S3_FORCE_PATH_STYLE=true

# OAuth 2.0 провайдеры (заглушки — заменить на реальные credentials)
# Для каждого провайдера нужны: Client ID, Client Secret, Redirect URI
# Redirect URI по умолчанию: http://localhost:4200/auth/callback

# VK (VK ID): https://id.vk.com/
OAUTH_VK_CLIENT_ID=your_vk_client_id
OAUTH_VK_CLIENT_SECRET=your_vk_client_secret
OAUTH_VK_REDIRECT_URI=http://localhost:4200/auth/callback/vk

# Google: https://console.cloud.google.com/apis/credentials
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:4200/auth/callback/google

# Apple: https://developer.apple.com/account/resources/identifiers/list/serviceId
# Требует Service ID, Team ID, Private Key
OAUTH_APPLE_SERVICE_ID=your_apple_service_id
OAUTH_APPLE_TEAM_ID=your_apple_team_id
OAUTH_APPLE_KEY_ID=your_apple_key_id
OAUTH_APPLE_PRIVATE_KEY_PATH=./path/to/apple_private_key.p8
OAUTH_APPLE_REDIRECT_URI=http://localhost:4200/auth/callback/apple

# Yandex: https://oauth.yandex.ru/client/new
OAUTH_YANDEX_CLIENT_ID=your_yandex_client_id
OAUTH_YANDEX_CLIENT_SECRET=your_yandex_client_secret
OAUTH_YANDEX_REDIRECT_URI=http://localhost:4200/auth/callback/yandex

# Общий секрет для подписи OAuth state (защита от CSRF)
OAUTH_STATE_SECRET=change-me-in-production-use-crypto-random-64-bytes
