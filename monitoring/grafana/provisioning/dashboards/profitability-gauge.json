          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(amount), 0)::double precision AS \"Доходность за 7 дней\"\nFROM payments\nWHERE status = 'completed'\n  AND payment_date >= NOW() - INTERVAL '7 days';",
          "refId": "A"
        }
      ],
      "title": "Доходность за 7 дней",
      "description": "Сумма успешных платежей за последние 7 дней",
