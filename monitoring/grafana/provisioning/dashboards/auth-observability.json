    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Client auth logs ingested through /api/logs/web.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", service=\"web\"} | json | event=\"web_log\" | msg=~\"auth\\\\.(login|register|password_reset).*\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent browser auth logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Backend auth RPC request logs with requestId for correlation.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", service=\"api\"} | json | path=~\"/notary\\\\.auth\\\\.v1alpha1\\\\.AuthService/(Login|Register|ForgotPassword|ResetPassword)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent backend auth RPC logs",
      "type": "logs"
