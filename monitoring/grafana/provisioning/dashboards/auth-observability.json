    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Successful user registrations during the last 7 days from the core registration Counter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 5,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(notary_users_registered_total[7d])",
          "legendFormat": "Registrations (7d)",
          "refId": "A"
        }
      ],
      "title": "User registrations (7d)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Failed backend auth attempts plus browser-side validation failures during the last 24 hours.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(increase(notary_auth_login_total{outcome=\"failed\"}[24h])) or vector(0)) + (sum(increase(notary_auth_registration_total{outcome=\"failed\"}[24h])) or vector(0)) + (sum(increase(notary_auth_password_reset_total{outcome=\"failed\"}[24h])) or vector(0)) + (sum(increase(notary_auth_browser_validation_failed_total[24h])) or vector(0))",
          "legendFormat": "Failed auth attempts (24h)",
          "refId": "A"
        }
      ],
      "title": "Failed auth attempts",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
