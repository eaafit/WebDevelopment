# Copy to .env.portal next to docker-compose.portal.yml (do not commit .env.portal).
# These defaults are for local full-stack Docker launch with docker-compose.local.yml.
# For VPS/production replace localhost URLs and SMTP/S3/YooKassa values with real ones.

DATABASE_URL=postgresql://admin:admin@postgres:5432/db?schema=public

PORTAL_PORT=4200
POSTGRES_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

JWT_ACCESS_SECRET=replace-with-long-random-hex
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
PASSWORD_RESET_BASE_URL=http://localhost:4200
PASSWORD_RESET_TTL_SEC=3600

MAIL_TRANSPORT=smtp
SMTP_HOST=mailpit
SMTP_PORT=1025
MAIL_FROM=noreply@notary.local
APP_NAME=Notary portal

# Angular build (portal image): set true to show sample-account hints on login.
# This is read at image build time, so rebuild portal after changing it.
NG_APP_SHOW_TEST_ACCOUNTS=true

# Optional local admin bootstrap. The API creates/promotes this user on startup.
PORTAL_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PORTAL_BOOTSTRAP_ADMIN_PASSWORD=AdminPass123!
PORTAL_BOOTSTRAP_ADMIN_FULL_NAME=Local Admin

# Sample login hints use these accounts:
# seed-user-000@seed.local / SeedPass123!
# seed-user-010@seed.local / SeedPass123!
# seed-user-020@seed.local / SeedPass123!
PORTAL_BOOTSTRAP_SAMPLE_USERS=true
SEED_USER_PASSWORD=SeedPass123!

# Required by the API at startup. Local auth flows do not upload files, so these
# can point to a future/local object storage until file upload is tested.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET_PAYMENT_DOCUMENTS=payment-documents
S3_BUCKET_ASSESSMENT_FILES=assessment-files

# Local placeholders for payment flows.
YOOKASSA_SHOP_ID=local_test_shop
YOOKASSA_SECRET_KEY=local_test_secret
PAYMENT_RETURN_URL_BASE=http://localhost:4200
PAYMENT_WEBHOOK_SECRET=local-webhook-secret
