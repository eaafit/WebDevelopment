# Copy to .env.portal next to docker-compose.portal.yml (do not commit .env.portal).
# Database must match postgres service in docker-compose.portal.yml (admin/admin, db db).

DATABASE_URL=postgresql://admin:admin@postgres:5432/db?schema=public

JWT_ACCESS_SECRET=replace-with-long-random-hex

# Browser origin of the portal (same as public site URL). Used by API CORS and mail links.
CORS_ORIGIN=https://your-domain.example
FRONTEND_URL=https://your-domain.example

# Angular build (portal image): default is off. Set `true` to show test-account hints on login. Only at `docker compose build` / `up --build`, not API runtime.
# NG_APP_SHOW_TEST_ACCOUNTS=true

# Optional: copy other variables from repo root .env.example (YooKassa, S3, SMTP, …).
